# Upstox API Credentials
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_REDIRECT_URI=https://127.0.0.1
UPSTOX_TOTP_SECRET=your_totp_secret_from_2fa_setup
UPSTOX_ACCESS_TOKEN=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_numeric_chat_id_here

# Trading Mode: True = sandbox/paper, False = live
PAPER_MODE=True

# Capital & Risk
TRADING_CAPITAL=600000
MAX_DAILY_LOSS=1000
TARGET_GROSS_DAILY=4500

# Upstox Login (for TOTP auto-login via Playwright)
UPSTOX_MOBILE=your_registered_mobile_number
UPSTOX_PIN=your_6digit_pin
